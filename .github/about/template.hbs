<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>SLT third-party notices</title>
<style>
  body { font-family: sans-serif; max-width: 56rem; margin: 2rem auto; padding: 0 1rem; }
  pre { background: #f4f4f4; padding: 1rem; overflow-x: auto; white-space: pre-wrap; }
  h2 { margin-top: 2.5rem; }
  ul { margin-bottom: 0.5rem; }
</style>
</head>
<body>
<h1>Third-party notices</h1>
<p>
  SLT incorporates third-party software. The licenses of the dependencies in its
  Rust build (including the statically-linked BoringSSL and quiche) are reproduced
  below, grouped by license. This file was generated by <code>cargo about</code>.
</p>
{{#each licenses}}
  <hr>
  <h2>{{name}}{{#if id}} <code>({{id}})</code>{{/if}}</h2>
  <p>Used by:</p>
  <ul>
  {{#each used_by}}
    <li>{{crate.name}} {{crate.version}}{{#if crate.repository}} &mdash; <a href="{{crate.repository}}">{{crate.repository}}</a>{{/if}}</li>
  {{/each}}
  </ul>
  <pre>{{text}}</pre>
{{/each}}
</body>
</html>
